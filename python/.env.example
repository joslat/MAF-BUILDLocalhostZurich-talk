# Copy to .env and fill in ONE backend block. chat.py loads this automatically.

# ── Azure OpenAI (resolved first; matches the reference AIConfig.cs) ─────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-10-21   # optional, this is the default

# ── or OpenAI ───────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4.1-mini        # optional, this is the default
